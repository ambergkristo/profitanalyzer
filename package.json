{
  "name": "profit-analyzer",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @profit-analyzer/core\" \"npm run dev -w @profit-analyzer/api\" \"npm run dev -w @profit-analyzer/web\"",
    "build": "npm run build -w @profit-analyzer/core && npm run build -w @profit-analyzer/api && npm run build -w @profit-analyzer/web",
    "test": "npm run test -w @profit-analyzer/core && npm run test -w @profit-analyzer/api && npm run test -w @profit-analyzer/web",
    "lint": "npm run lint -w @profit-analyzer/core && npm run lint -w @profit-analyzer/api && npm run lint -w @profit-analyzer/web",
    "typecheck": "npm run typecheck -w @profit-analyzer/core && npm run typecheck -w @profit-analyzer/api && npm run typecheck -w @profit-analyzer/web",
    "validate:synthetic": "tsx scripts/validateSynthetic.ts",
    "validate:demo": "tsx scripts/validateDemo.ts",
    "validate:invoice": "tsx scripts/validateInvoice.ts",
    "validate:ocr": "tsx scripts/validateOcr.ts",
    "validate:ocr:provider": "tsx scripts/validateOcrProvider.ts",
    "validate:pilot": "tsx scripts/validatePilot.ts",
    "validate:env": "tsx scripts/validateEnv.ts",
    "validate:auth": "tsx scripts/validateAuth.ts",
    "validate:runtime": "tsx scripts/validateRuntime.ts",
    "validate:production-readiness": "tsx scripts/validateProductionReadiness.ts",
    "validate:mobile": "tsx scripts/validateMobile.ts",
    "validate:onboarding": "tsx scripts/validateOnboarding.ts",
    "validate:invoice-pipeline": "tsx scripts/validateInvoicePipeline.ts",
    "validate:billing": "tsx scripts/validateBilling.ts",
    "validate:launch-gate": "tsx scripts/validateLaunchGate.ts",
    "validate:deployment": "tsx scripts/validateDeployment.ts",
    "validate:hosted": "tsx scripts/validateHosted.ts",
    "validate:ui-reset": "tsx scripts/validateUiReset.ts",
    "screenshot:ui": "tsx scripts/screenshotUi.ts",
    "benchmark:ocr": "tsx scripts/benchmarkOcr.ts",
    "db:generate": "npm run db:generate -w @profit-analyzer/api",
    "db:migrate": "npm run db:migrate -w @profit-analyzer/api",
    "db:seed": "npm run db:seed -w @profit-analyzer/api",
    "db:deploy:migrate": "npm run db:migrate",
    "db:deploy:seed": "npm run db:seed",
    "db:reset:local": "npm run db:reset:local -w @profit-analyzer/api",
    "validate:db": "tsx scripts/validateDb.ts",
    "build:production": "npm run build",
    "start:api": "node apps/api/dist/index.js",
    "preview:web": "npm run build -w @profit-analyzer/web && npm exec -- vite preview --host 0.0.0.0 --port 4173 --config apps/web/vite.config.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "concurrently": "^9.0.1",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "tsx": "^4.19.2",
    "typescript-eslint": "^8.20.0"
  }
}
